# Variables de entorno del webhook de Stripe (workers/stripe-webhook)
#
# En Cloudflare Workers los secretos NO van en un .env: se cargan con
#   npx wrangler secret put STRIPE_WEBHOOK_SECRET
#   npx wrangler secret put RESEND_API_KEY
# Para desarrollo local con `wrangler dev`, copia este archivo a
# .dev.vars (mismo formato KEY=value) dentro de workers/stripe-webhook.

# Clave secreta de Stripe (sk_test_... / sk_live_...).
# El webhook actual NO la necesita (solo valida firma y lee el payload del
# evento), pero se documenta por si se agrega lookup de sesiones/line items.
STRIPE_SECRET_KEY=sk_test_xxx

# Signing secret del endpoint de webhook (whsec_...).
# Sale del Stripe Dashboard -> Developers -> Webhooks -> tu endpoint,
# o de `stripe listen --print-secret` en pruebas locales.
STRIPE_WEBHOOK_SECRET=whsec_xxx

# API key de Resend (https://resend.com/api-keys) para mandar los correos.
RESEND_API_KEY=re_xxx

# A donde llega la alerta de cada pago (emails/payment-alert.html).
OWNER_ALERT_EMAIL=contacto@mimarca.me

# Remitente de los correos (el dominio debe estar verificado en Resend).
FROM_EMAIL="mimarca <pedidos@mimarca.me>"

# Correo de soporte que aparece en el correo de confirmacion al cliente.
SUPPORT_EMAIL=contacto@mimarca.me

# --- Portal de cliente (mi-cuenta): /access, /upload, /notify/* ---

# Secret compartido para las rutas /notify/published y /notify/change-received
# (el equipo las dispara a mano con curl/Postman, no hay panel de admin).
# Generalo con algo como `openssl rand -hex 24`.
ADMIN_SECRET=cambia-esto-por-algo-largo-y-aleatorio

# URL publica del bucket R2 donde caen los logos/fotos que suben los clientes
# desde /upload (ver seccion R2 en README.md). Ejemplo con dominio propio:
# https://uploads.mimarca.me — o la URL publica que da Cloudflare al bucket.
R2_PUBLIC_BASE_URL=https://uploads.mimarca.me
